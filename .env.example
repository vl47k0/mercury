# Copy to .env for local dev. In the cluster these come from the Deployment env
# / a Secret. mercury runs behind authd (X-JWT-Sub trusted).
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
POSTGRES_DB=mercury
POSTGRES_USER=mercury
POSTGRES_PASSWORD=mercury
POSTGRES_HOST=192.168.1.183
POSTGRES_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
